@model IEnumerable<FitnessFox.Web.Models.User>

<h2>🏆 Classement des Joueurs</h2>

<table class="table table-hover">
    <thead class="thead-dark">
        <tr>
            <th>Pseudo</th>
            <th>Niveau</th>
            <th>Score Total</th>
            <th>Missions Terminées</th>
            <th>Série (Streak)</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td style="font-weight:bold; font-size:1.1em">🦊 @item.Pseudo</td>
                <td>
                    <span class="badge bg-primary">Niveau @((item.Score / 100) + 1)</span>
                </td>
                <td style="color:orange; font-weight:bold">@item.Score pts</td>
                <td>@item.TotalMissionsCompleted ✅</td>
                <td>
                    @if (item.CurrentStreak > 0)
                    {
                        <span>@item.CurrentStreak jours 🔥</span>
                    }
                    else
                    {
                        <span class="text-muted">0 jour</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>